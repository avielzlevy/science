# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
INTERNAL_API_KEY=your-internal-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/research_reels?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# TTL in seconds — 7 days
REDIS_SKIT_TTL=604800
# Category index TTL — 1 day (refreshed on new skits)
REDIS_CATEGORY_INDEX_TTL=86400

# ── AI: OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Preset B — The Visionary
OPENAI_TEMPERATURE=0.7

# ── AI: Anthropic (fallback) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# ── Image Generation ──────────────────────────────────────────────────────────
# OpenAI DALL-E 3 is used by default; swap URL + key for any compatible provider
IMAGE_GEN_PROVIDER=dalle
IMAGE_GEN_MODEL=dall-e-3
IMAGE_GEN_SIZE=1792x1024

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_PROVIDER=openai
TTS_MODEL=tts-1-hd
TTS_VOICE=onyx

# ── Academic APIs ─────────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

# Nature / Springer API
NATURE_API_KEY=
NATURE_BASE_URL=https://api.springernature.com/openaccess/json

# IEEE Xplore
IEEE_API_KEY=
IEEE_BASE_URL=https://ieeexploreapi.ieee.org/api/v1/search/articles

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=30
